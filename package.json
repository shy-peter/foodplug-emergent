{
  "name": "foodplug-emergent",
  "private": true,
  "dependencies": {
    "concurrently": "^9.2.1"
  },
  "scripts": {
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix frontend run dev\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "start": "npm --prefix frontend run start",
    "postinstall": "npm --prefix frontend install --legacy-peer-deps --no-audit --no-fund",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend run test"
  }
}
